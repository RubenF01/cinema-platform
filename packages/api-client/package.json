{
  "name": "@cimena/api-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "format:check": "prettier --ignore-path ../../.prettierignore --check .",
    "generate:api": "node ../../scripts/generate-api.mjs"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.6.0"
  },
  "devDependencies": {
    "@cimena/eslint-config": "workspace:*",
    "@cimena/typescript-config": "workspace:*",
    "@hey-api/openapi-ts": "^0.57.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
