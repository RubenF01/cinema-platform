ENVIRONMENT=local
API_PORT=8000
API_PUBLIC_URL=http://localhost:8000
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app_password
DATABASE_URL=postgresql+psycopg://app:app_password@localhost:5432/app

REDIS_URL=redis://localhost:6379/0
SESSION_COOKIE_NAME=cimena_session
SESSION_TTL_SECONDS=604800
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=app-local
MINIO_SECURE=false

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.local
SMTP_FROM_NAME=Local App

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8000
